{
  "name": "@membank/dashboard",
  "version": "0.2.3",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/draekien-industries/membank.git",
    "directory": "packages/dashboard"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && tsdown",
    "dev": "concurrently --kill-others \"node --watch --import tsx/esm src/server/dev.ts\" \"vite\"",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.app.json",
    "lint": "biome check ./src",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@base-ui/react": "^1.0.0",
    "@fontsource-variable/geist-mono": "^5.2.7",
    "@fontsource-variable/space-grotesk": "^5.2.10",
    "@hono/node-server": "^1.13.0",
    "@membank/core": "workspace:*",
    "@phosphor-icons/react": "^2.1.10",
    "@tanstack/query-core": "^5.100.6",
    "@tanstack/query-db-collection": "^1.0.36",
    "@tanstack/react-db": "^0.1.83",
    "@tanstack/react-hotkeys": "^0.10.0",
    "@tanstack/react-router": "^1.168.25",
    "@tanstack/router-plugin": "^1.167.28",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hono": "^4.7.0",
    "next-themes": "^0.4.6",
    "open": "^10.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "shadcn": "^4.6.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.0.0",
    "tw-animate-css": "^1.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^9.0.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.0.0",
    "typescript": "^6.0.3",
    "vite": "^6.0.0"
  }
}
